rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // app_data: read by anyone, write only by the Cloud Function (admin SDK bypasses rules)
    match /app_data/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // wc2026stats/aggregated: read by all app users; written only by Cloud Function
    match /wc2026stats/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // wc2026_match_cache: internal Cloud Function cache; not readable by the app
    match /wc2026_match_cache/{doc} {
      allow read: if false;
      allow write: if false;
    }
  }
}
